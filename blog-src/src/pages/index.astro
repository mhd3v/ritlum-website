---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<BaseLayout
  title="Ritlum Blog"
  description="Notes on building habits that stick, and the NFC desk tracker that makes logging them effortless."
>
  <main>
    <header>
      <p class="eyebrow">Ritlum Blog</p>
      <h1>Habits, brought into the light</h1>
    </header>

    <ul class="post-list">
      {
        posts.map((post) => (
          <li>
            <a class="post-card" href={`/blog/${post.id}/`}>
              <span class="post-date">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <span class="read-more">Read →</span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>

<style>
  main {
    width: min(100% - 40px, 760px);
    margin: 0 auto;
    padding: 88px 0 100px;
  }

  .eyebrow {
    margin: 0 0 18px;
    color: var(--faint);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(36px, 7vw, 54px);
    line-height: 1.04;
    letter-spacing: -2px;
  }

  .post-list {
    list-style: none;
    margin: 52px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .post-card {
    display: block;
    padding: 26px 28px;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 20px;
    color: var(--ink);
    text-decoration: none;
    box-shadow: 0 1px 2px rgba(20, 20, 20, 0.03);
    transition: box-shadow 200ms ease, transform 200ms ease;
  }

  .post-card:hover {
    box-shadow:
      0 1px 2px rgba(20, 20, 20, 0.04),
      0 12px 32px rgba(20, 20, 20, 0.06);
    transform: translateY(-1px);
  }

  .post-date {
    color: var(--faint);
    font-size: 13px;
    font-weight: 550;
  }

  .post-card h2 {
    margin: 10px 0 8px;
    font-size: 23px;
    letter-spacing: -0.5px;
    line-height: 1.2;
  }

  .post-card p {
    margin: 0;
    color: var(--muted);
    font-size: 15.5px;
    line-height: 1.6;
  }

  .read-more {
    display: inline-block;
    margin-top: 14px;
    color: var(--blue);
    font-size: 14px;
    font-weight: 600;
  }

  @media (max-width: 600px) {
    main {
      width: min(100% - 32px, 760px);
      padding: 62px 0 74px;
    }
  }
</style>
